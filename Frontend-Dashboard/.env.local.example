# Copy to .env.local (same folder). Next.js loads .env.local automatically.

# --- Login gate ---
# "false" = open dashboard without signing in (good for UI-only work).
NEXT_PUBLIC_AUTH_REQUIRED=false

# --- API routing (recommended) ---
# Leave NEXT_PUBLIC_API_BASE unset so the browser uses same-origin /api/portal-proxy/...
# and Next.js forwards to Django (fixes many 404/CORS issues).

# Server-side only: where the Next.js proxy sends API traffic (Django).
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# Optional: show these on the login page (must match Backend seed password).
NEXT_PUBLIC_DEMO_USERNAME=demo
NEXT_PUBLIC_DEMO_PASSWORD=SyndicateDev2026!

# Only if you need the browser to call Django directly (must match CORS on Django):
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# Optional: Programs / Continue Program iframe (full embed URL, e.g. https://www.youtube-nocookie.com/embed/VIDEO_ID)
# NEXT_PUBLIC_PROGRAM_PROMO_EMBED_URL=
