# Optional: Django Syndicate API (default is http://127.0.0.1:8000/api)
NEXT_PUBLIC_SYNDICATE_API_URL=http://127.0.0.1:8000/api

# Railway: backend public URL must include https:// and end with /api, e.g.:
# NEXT_PUBLIC_SYNDICATE_API_URL=https://your-django-service.up.railway.app/api
# Wrong: hostname only, or missing /api — signup/login fetch will fail.
