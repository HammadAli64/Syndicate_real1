# Copy to .env.local and adjust.

# --- Recommended local dev (browser calls Django directly; same as login/signup pages) ---
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# Optional alias (either this or NEXT_PUBLIC_API_BASE_URL is enough now):
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# --- Alternative: leave both unset to use same-origin /api/portal-proxy/... ---
# Then Next.js must reach Django (see next.config.js):
# BACKEND_INTERNAL_URL=http://127.0.0.1:8000
# If Next runs inside Docker and Django on the Windows host:
# BACKEND_INTERNAL_URL=http://host.docker.internal:8000

# --- OTP + Stripe member flow (merged from old `frontend/` app) ---
# Leave NEXT_PUBLIC_API_BASE_URL empty to use same-origin /api/auth/... (proxied in next.config.js).
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# NEXT_PUBLIC_POST_LOGIN_REDIRECT_URL=https://the-syndicate.com/
# Optional: set URL prefix for OTP UI (default is root auth routes: /login, /signup, /verify-otp)
# NEXT_PUBLIC_SYNDICATE_OTP_UI_BASE=/syndicate-otp
