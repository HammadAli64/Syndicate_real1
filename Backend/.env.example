EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=your-email@gmail.com
OTP_EXPIRES_MINUTES=10
FRONTEND_BASE_URL=http://localhost:3000
# Local next dev is http://localhost:3000 — use http here; https://localhost breaks cookies and OTP redirect.
CHECKOUT_AMOUNT_PENCE=33300
# Legacy fallback still supported by settings:
# PCHECKOUT_AMOUNT_PENCE=33300
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Optional: comma-separated Checkout methods (default card,link,pay_by_bank — add paypal when enabled)
# STRIPE_CHECKOUT_PAYMENT_METHOD_TYPES=card,link,pay_by_bank

# --- HLS streaming (Celery + FFmpeg + R2) ---
# FFmpeg binary: bundled via pip package imageio-ffmpeg (no system install). Optional override:
# FFMPEG_BINARY=C:\path\to\ffmpeg.exe
# REDIS_URL=redis://127.0.0.1:6379/0
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# Run transcodes in-process (no worker) for quick local tests:
# CELERY_TASK_ALWAYS_EAGER=true
# Public origin used in the returned index.m3u8 URL (local: Django origin; prod: CDN root):
# VIDEO_CDN_PUBLIC_BASE_URL=http://127.0.0.1:8000
# Signed playback URLs (token + expires) for index.m3u8 and all segment/key URIs:
# STREAM_SIGNED_URL_TTL_SECONDS=900
# STREAM_SIGNING_SECRET=replace-with-long-random-secret
# R2 / S3 (same keys as django-storages): AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
# AWS_STORAGE_BUCKET_NAME, AWS_S3_ENDPOINT_URL, AWS_S3_REGION_NAME=auto
# USE_S3_OBJECT_STORAGE must not be disabled if you want uploads from the Celery task.

# --- HLS streaming (Celery + FFmpeg + R2) ---
# REDIS_URL=redis://127.0.0.1:6379/0
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
