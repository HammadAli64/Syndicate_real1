# Copy to .env for local dev (never commit real secrets).

DJANGO_SECRET_KEY=change-me-in-production
# Local: true | Railway: false (or omit; RAILWAY_ENVIRONMENT defaults debug off)
DJANGO_DEBUG=true

# --- PostgreSQL (Railway) ---
# Easiest: add the Postgres plugin to your backend service. Railway injects DATABASE_URL
# automatically — you usually do not need to paste anything.
#
# Manual / reference URL shape:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# If only split vars exist (e.g. copied from Railway Postgres service):
# PGHOST=...
# PGPORT=5432
# PGUSER=...
# PGPASSWORD=...
# PGDATABASE=...
#
# Optional fallbacks (some setups use these names instead of DATABASE_URL):
# DATABASE_PRIVATE_URL=
# DATABASE_PUBLIC_URL=
#
# Set to false only for local Postgres without SSL (not typical on Railway):
# DATABASE_SSL_REQUIRE=true

# Optional: comma-separated hostnames (Railway also uses RAILWAY_PUBLIC_DOMAIN)
# ALLOWED_HOSTS=

# Frontend origin(s) for CORS/CSRF — full URL with https:// (no path). Example:
# CORS_ALLOWED_ORIGINS=https://your-frontend.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://your-frontend.up.railway.app
# (If unset, the backend still adds https://$RAILWAY_PUBLIC_DOMAIN for /admin/ CSRF.)
# Wrong: my-app.up.railway.app (missing https://) — browsers will not match.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: max in-memory multipart size in MB (admin/API uploads). Default 32.
# DATA_UPLOAD_MAX_MB=32

# Django admin (optional — ensure_superuser runs on deploy via railway_start.sh)
# Railway Variables: same values you type at /admin/login/ (env does not auto-fill the form).
# Each deploy updates that user's password + staff flags from these vars (unless NO_PASSWORD_SYNC set).
# DJANGO_SUPERUSER_EMAIL=you@example.com
# DJANGO_SUPERUSER_PASSWORD=use-a-long-random-secret
# Optional: set to 1 if you manage the password only via createsuperuser/changepassword (no env updates)
# DJANGO_SUPERUSER_NO_PASSWORD_SYNC=1

# Cloudinary (uploads / FileField). Set in Railway Variables — do not commit secrets.
# Option A — single URL (recommended):
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Option B — separate vars:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- S3-compatible object storage (Tigris, Cloudflare R2, AWS S3) ---
# When bucket + access key + secret are set, Django default file storage uses this backend
# (mindset uploads go to uploads/<sha256>.<ext>; challenge attachments use the same storage).
# S3 takes precedence over Cloudinary if both are configured.
# Tigris: keys usually start with tid_ / tsec_; endpoint defaults to https://t3.storage.dev if omitted.
# AWS_S3_ENDPOINT_URL=https://t3.storage.dev
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_ACCESS_KEY_ID=tid_...
# AWS_SECRET_ACCESS_KEY=tsec_...
# AWS_S3_REGION_NAME=auto
# Optional: USE_S3_OBJECT_STORAGE=false to disable while keeping keys in the environment
